{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext", // "commonjs" is for Node, not Vite
    "moduleResolution": "Node",
    "outDir": "./public/build", // You can keep this if you want, though Vite handles build output itself
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "types": ["vite/client"]
  },
  "include": [
    "resources/js/**/*.js",
    "resources/js/**/*.ts",
    "resources/js/**/*.vue"
  ],
  "exclude": [
    "node_modules"
  ]
}
